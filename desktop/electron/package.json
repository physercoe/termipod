{
  "name": "termipod-electron",
  "private": true,
  "version": "0.0.0-dev",
  "description": "TermiPod desktop Electron shell (ADR-055 M1). Wraps the same Vite build (../dist) the Tauri shell ships; the frontend talks to it through the runtime-agnostic src/bridge/. Self-contained package (own deps) so the Tauri release build never installs Electron.",
  "author": "TermiPod contributors",
  "main": "out/main.cjs",
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "extract-zip": "^2.0.1",
    "jszip": "^3.10.1",
    "node-pty": "^1.0.0",
    "ssh2": "^1.16.0",
    "sshpk": "^1.18.0",
    "ws": "^8.18.0"
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test 'src/**/*.test.ts'",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@types/aws4": "^1.11.6",
    "@types/node": "^22.14.0",
    "@types/ssh2": "^1.15.0",
    "@types/sshpk": "^1.17.0",
    "@types/ws": "^8.5.12",
    "aws4": "^1.13.2",
    "electron": "^43.1.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.2"
  }
}
