{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "TermiPod design tokens — the neutral DTCG source of truth for both clients (WS1 of docs/plans/desktop-control-plane.md, implements ADR-051). The Flutter app's lib/theme/tokens.dart + design_colors.dart are the hand-authored, doc-carrying mirror; design-tokens/build.mjs verifies they match these values (CI drift-guard) and emits build/tokens.css for the web/desktop client. Colors are opaque (Flutter Color(0xFF<hex>)).",

  "spacing": {
    "$description": "4px grid (ADR-047 D-2) → Flutter Spacing.*",
    "s2":  { "$value": 2,  "$type": "dimension" },
    "s4":  { "$value": 4,  "$type": "dimension" },
    "s8":  { "$value": 8,  "$type": "dimension" },
    "s12": { "$value": 12, "$type": "dimension" },
    "s16": { "$value": 16, "$type": "dimension" },
    "s24": { "$value": 24, "$type": "dimension" },
    "s32": { "$value": 32, "$type": "dimension" }
  },

  "radius": {
    "$description": "M3 shape scale (ADR-047 D-3) → Flutter Radii.* (the *Border composites are derived in Dart)",
    "xs":      { "$value": 4,   "$type": "dimension" },
    "sm":      { "$value": 8,   "$type": "dimension" },
    "md":      { "$value": 12,  "$type": "dimension" },
    "lg":      { "$value": 16,  "$type": "dimension" },
    "stadium": { "$value": 999, "$type": "dimension" }
  },

  "fontSize": {
    "$description": "6-step type scale (ADR-047 D-4) → Flutter FontSizes.*",
    "label":      { "$value": 11, "$type": "dimension" },
    "caption":    { "$value": 12, "$type": "dimension" },
    "bodySmall":  { "$value": 13, "$type": "dimension" },
    "body":       { "$value": 14, "$type": "dimension" },
    "subtitle":   { "$value": 16, "$type": "dimension" },
    "title":      { "$value": 18, "$type": "dimension" },
    "titleLarge": { "$value": 20, "$type": "dimension" }
  },

  "iconSize": {
    "$description": "Icon-size scale (ADR-047 D-4/§6) → Flutter IconSizes.*",
    "sm": { "$value": 14, "$type": "dimension" },
    "md": { "$value": 18, "$type": "dimension" },
    "lg": { "$value": 22, "$type": "dimension" }
  },

  "color": {
    "$description": "Palette (ADR-047 D-5/D-6) → Flutter DesignColors.*. Opaque; Dart stores Color(0xFF<hex>).",

    "primary":     { "$value": "#00C0D1", "$type": "color" },
    "primaryDark": { "$value": "#009AA8", "$type": "color" },
    "secondary":   { "$value": "#F59E0B", "$type": "color" },

    "backgroundDark":  { "$value": "#0E0E11", "$type": "color" },
    "backgroundLight": { "$value": "#F9FAFB", "$type": "color" },

    "surfaceDark": { "$value": "#1E1F27", "$type": "color" },
    "canvasDark":  { "$value": "#101116", "$type": "color" },
    "inputDark":   { "$value": "#0B0F13", "$type": "color" },

    "borderDark":  { "$value": "#2A2B36", "$type": "color" },
    "borderLight": { "$value": "#E5E7EB", "$type": "color" },

    "textPrimary":   { "$value": "#FFFFFF", "$type": "color" },
    "textSecondary": { "$value": "#9CA3AF", "$type": "color" },
    "textMuted":     { "$value": "#868C96", "$type": "color" },

    "textPrimaryLight":   { "$value": "#111827", "$type": "color" },
    "textSecondaryLight": { "$value": "#4B5563", "$type": "color" },
    "textMutedLight":     { "$value": "#646B73", "$type": "color" },

    "surfaceLight": { "$value": "#FFFFFF", "$type": "color" },
    "canvasLight":  { "$value": "#F3F4F6", "$type": "color" },
    "inputLight":   { "$value": "#F9FAFB", "$type": "color" },

    "success": { "$value": "#22C55E", "$type": "color" },
    "error":   { "$value": "#EF4444", "$type": "color" },
    "warning": { "$value": "#F59E0B", "$type": "color" },

    "info":   { "$value": "#6366F1", "$type": "color" },
    "slate":  { "$value": "#64748B", "$type": "color" },
    "violet": { "$value": "#B394FF", "$type": "color" },

    "warningContainer":      { "$value": "#422E08", "$type": "color" },
    "warningContainerLight": { "$value": "#FEF3C7", "$type": "color" },
    "onWarningContainer":      { "$value": "#FCD34D", "$type": "color" },
    "onWarningContainerLight": { "$value": "#92400E", "$type": "color" },

    "successOnLight": { "$value": "#166534", "$type": "color" },

    "terminalGreen":   { "$value": "#22C55E", "$type": "color" },
    "terminalBlue":    { "$value": "#3B82F6", "$type": "color" },
    "terminalRed":     { "$value": "#EF4444", "$type": "color" },
    "terminalYellow":  { "$value": "#EAB308", "$type": "color" },
    "terminalCyan":    { "$value": "#06B6D4", "$type": "color" },
    "terminalMagenta": { "$value": "#A855F7", "$type": "color" },

    "keyBackground":      { "$value": "#2A2B35", "$type": "color" },
    "keyBackgroundHover": { "$value": "#353640", "$type": "color" },
    "footerBackground":   { "$value": "#14151A", "$type": "color" },

    "keyBackgroundLight":      { "$value": "#E5E7EB", "$type": "color" },
    "keyBackgroundHoverLight": { "$value": "#D1D5DB", "$type": "color" },
    "footerBackgroundLight":   { "$value": "#F3F4F6", "$type": "color" },

    "connectedCardDark":       { "$value": "#14532D", "$type": "color" },
    "connectedCardBorderDark": { "$value": "#166534", "$type": "color" },
    "connectedCardTextDark":   { "$value": "#4ADE80", "$type": "color" },
    "connectingCardDark":       { "$value": "#153E42", "$type": "color" },
    "connectingCardBorderDark":  { "$value": "#1F5F66", "$type": "color" },

    "connectedCardLight":       { "$value": "#DCFCE7", "$type": "color" },
    "connectedCardBorderLight": { "$value": "#86EFAC", "$type": "color" },
    "connectedCardTextLight":   { "$value": "#166534", "$type": "color" },
    "connectingCardLight":       { "$value": "#E0F7FA", "$type": "color" },
    "connectingCardBorderLight": { "$value": "#80DEEA", "$type": "color" }
  }
}
