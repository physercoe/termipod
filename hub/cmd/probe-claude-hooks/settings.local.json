{
  "_comment": "Drop this file at <test-workdir>/.claude/settings.local.json. Replace $HOME with an absolute path to the probe script if your shell doesn't expand $HOME inside hook commands. timeout=5s is generous; the probe script normally returns in <50ms.",

  "permissions": {
    "defaultMode": "bypassPermissions"
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/cc-hook-probe/hook-probe.sh PreToolUse",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/cc-hook-probe/hook-probe.sh PostToolUse",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/cc-hook-probe/hook-probe.sh Notification",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/cc-hook-probe/hook-probe.sh UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/cc-hook-probe/hook-probe.sh Stop",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/cc-hook-probe/hook-probe.sh SubagentStop",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/cc-hook-probe/hook-probe.sh PreCompact",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/cc-hook-probe/hook-probe.sh SessionStart",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/cc-hook-probe/hook-probe.sh SessionEnd",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
