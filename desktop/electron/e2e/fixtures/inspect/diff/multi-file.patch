+"""Guarded helpers extracted from sample.py."""
+
+
+def safe_mean(values):
+    return sum(values) / len(values) if values else 0.0
+
+
+def normalize(values):
+    m = safe_mean(values)
+    return [v / m for v in values] if m else []
