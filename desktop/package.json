{
  "name": "termipod-desktop",
  "private": true,
  "version": "2026.723.247",
  "type": "module",
  "description": "TermiPod desktop control plane — the unified web-tech client shell (WS2 of docs/plans/desktop-control-plane.md). Browser-target build; the Electron shell (desktop/electron) packages it (ADR-055).",
  "scripts": {
    "dev": "npm run sync:tokens && npm run sync:excalidraw && vite",
    "build": "npm run sync:tokens && npm run sync:excalidraw && tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "sync:tokens": "node ../design-tokens/build.mjs && cp ../design-tokens/build/tokens.css src/styles/tokens.css",
    "sync:excalidraw": "node scripts/sync-excalidraw-assets.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
